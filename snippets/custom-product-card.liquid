{% liquid
  assign card_product = product
  if card_product == blank
    assign card_product = closest.product
  endif

  if card_product == blank
    echo '<!-- custom-product-card: no product provided -->'
    break
  endif

  assign selected_variant = card_product.selected_or_first_available_variant
  assign brand_name = card_product.vendor
  assign product_title = card_product.title

  assign on_sale = false
  if selected_variant.compare_at_price > selected_variant.price
    assign on_sale = true
  endif

  assign primary_image = selected_variant.featured_media | default: card_product.featured_media
  assign secondary_image = blank

  if selected_variant.metafields.custom.secondary_image != blank
    assign secondary_image = selected_variant.metafields.custom.secondary_image.value
  elsif card_product.images.size > 1
    assign secondary_image = card_product.images[1]
  endif

  assign option_index = nil
  for option in card_product.options_with_values
    assign option_name = option.name | downcase
    if option_name contains 'color' or option_name contains 'colour'
      assign option_index = forloop.index0
      break
    endif
  endfor

  assign card_id = 'custom-product-card-' | append: section.id | append: '-' | append: card_product.id
%}

{{ 'tailwind-output.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-product-card.js' | asset_url }}" defer></script>

<div
  id="{{ card_id }}"
  data-product-card
  class="custom-product-card w-full max-w-[286px]"
>
  <a href="{{ card_product.url }}" class="block text-inherit no-underline" data-product-link>
    <div class="relative aspect-[286/348] overflow-hidden rounded-[10px] border border-[#D7D7D7]">
      <div
        class="absolute left-[18px] top-[18px] z-[2] inline-flex min-h-[29px] max-h-[29px] items-center justify-center rounded-full border border-[#FF2A1F] bg-white px-[18px] py-[6px] text-[15.37px] font-medium leading-none text-[#FF2A1F] {% unless on_sale %}hidden{% endunless %}"
        data-sale-badge
      >
        On Sale!
      </div>

      <div class="relative h-full w-full">
        {% liquid
          assign primary_src = ''
          assign primary_alt = ''
          assign primary_width = ''
          assign primary_height = ''

          if primary_image != blank
            assign primary_src = primary_image | image_url: width: 900
            assign primary_alt = primary_image.alt | default: product_title | escape
            assign primary_width = primary_image.width
            assign primary_height = primary_image.height
          endif
        %}

        {% if primary_src != blank %}
          <img
            src="{{ primary_src }}"
            alt="{{ primary_alt }}"
            class="absolute inset-0 h-full w-full object-contain transition-opacity duration-300 ease-out product-card-primary-image"
            loading="lazy"
            width="{{ primary_width }}"
            height="{{ primary_height }}"
            data-primary-image
          >
        {% endif %}


        {% liquid
        assign secondary_src = ''
        assign secondary_alt = ''
        assign secondary_width = ''
        assign secondary_height = ''
        assign secondary_hidden = true

        if secondary_image != blank
          assign secondary_src = secondary_image | image_url: width: 900
          assign secondary_alt = secondary_image.alt | default: product_title | escape
          assign secondary_width = secondary_image.width
          assign secondary_height = secondary_image.height
          assign secondary_hidden = false
        endif
      %}

      <img
        alt="{{ secondary_alt }}"
        class="absolute inset-0 h-full w-full object-contain opacity-0 transition-opacity duration-300 ease-out product-card-secondary-image"
        loading="lazy"
        width="{{ secondary_width }}"
        height="{{ secondary_height }}"
        {% if secondary_width != blank %}width="{{ secondary_width }}"{% endif %}
        {% if secondary_height != blank %}height="{{ secondary_height }}"{% endif %}
        data-secondary-image
        {% if secondary_hidden %}style="display:none;"{% endif %}
      >
    </div>
  </div>
  </a>

  {% if option_index != nil %}
    {% assign selected_color_value = selected_variant.options[option_index] %}

    <div class="isolate mt-[18px] flex flex-wrap items-center gap-[10px]" role="list" aria-label="Color options">
      {% assign color_option = card_product.options_with_values[option_index] %}

      {% for color_value in color_option.values %}
        {% assign swatch_variant = blank %}

        {% for variant in card_product.variants %}
          {% if variant.options[option_index] == color_value %}
            {% assign swatch_variant = variant %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% if swatch_variant != blank %}
          {% liquid
            assign variant_on_sale = false
            if swatch_variant.compare_at_price > swatch_variant.price
              assign variant_on_sale = true
            endif

            assign variant_primary = swatch_variant.featured_media | default: card_product.featured_media
            assign variant_secondary = blank
            if swatch_variant.metafields.custom.secondary_image != blank
              assign variant_secondary = swatch_variant.metafields.custom.secondary_image.value
            endif

            assign swatch_color_key = color_value | strip | downcase
            assign swatch_color = '#D9D9D9'

            case swatch_color_key
              when 'orange'
                assign swatch_color = '#FF6A2A'
              when 'green'
                assign swatch_color = '#93B95B'
              when 'blue'
                assign swatch_color = '#0E6BA8'
              when 'yellow'
                assign swatch_color = '#E8D372'
              when 'pink'
                assign swatch_color = '#E6B6E8'
              when 'navy'
                assign swatch_color = '#1D2D62'
              when 'light green'
                assign swatch_color = '#93B95B'
            endcase
          %}

          <button
            type="button"
            class="swatch-button relative inline-flex h-[20px] w-[20px] shrink-0 items-center justify-center rounded-full border p-0 transition-transform duration-150 hover:scale-105 {% if color_value == selected_color_value %}is-active-swatch{% endif %}"
            aria-label="{{ color_value | escape }}"
            aria-pressed="{% if color_value == selected_color_value %}true{% else %}false{% endif %}"
            data-swatch
            data-variant-id="{{ swatch_variant.id }}"
            data-variant-url="{{ swatch_variant.url }}"
            data-title="{{ product_title | escape }}"
            data-vendor="{{ brand_name | escape }}"
            data-price="{{ swatch_variant.price | money | escape }}"
            data-compare-price="{{ swatch_variant.compare_at_price | money | escape }}"
            data-on-sale="{% if variant_on_sale %}true{% else %}false{% endif %}"
            data-primary-image="{% if variant_primary != blank %}{{ variant_primary | image_url: width: 900 }}{% endif %}"
            data-primary-alt="{{ variant_primary.alt | default: product_title | escape }}"
            data-secondary-image="{% if variant_secondary != blank %}{{ variant_secondary | image_url: width: 900 }}{% endif %}"
            data-secondary-alt="{{ variant_secondary.alt | default: product_title | escape }}"
            style="background-color: {{ swatch_color }};"
          >
            {% comment %} <span class="sr-only">{{ color_value }}</span> {% endcomment %}
          </button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  <div class="mt-[18px]">
    {% if brand_name != blank %}
      <div class="text-[14px] leading-[1.3] text-[#111111]" data-product-vendor>{{ brand_name }}</div>
    {% endif %}

    <a href="{{ card_product.url }}" class="mt-[6px] block text-inherit no-underline" data-product-link>
      <h3 class="m-0 text-[16px] font-semibold leading-[1.15] text-[#0E4A7B]" data-product-title>{{ product_title }}</h3>
    </a>

    <div class="mt-[10px] flex items-center gap-[12px] text-[14px] leading-none">
      <span class="text-[#111111] line-through {% unless on_sale %}hidden{% endunless %}" data-compare-price>
        {{ selected_variant.compare_at_price | money }}
      </span>
      <span class="{% if on_sale %}text-[#FF2A1F]{% else %}text-[#111111]{% endif %}" data-price>
        {{ selected_variant.price | money }}
      </span>
    </div>
  </div>
</div>
