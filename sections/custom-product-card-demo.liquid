{% schema %}
{
  "name": "Custom product card demo",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Custom product card demo"
    }
  ]
}
{% endschema %}

{% assign selected_collection = section.settings.collection %}
{% assign products_to_show = section.settings.products_to_show %}
{% assign heading = section.settings.heading %}

<section class="px-6 py-10 md:px-10 lg:px-16">
  <div class="mx-auto max-w-[1280px]">
    {% if heading != blank %}
      <h2 class="mb-8 text-[24px] font-semibold leading-none text-[#222222]">
        {{ heading }}
      </h2>
    {% endif %}

    {% if selected_collection != blank and selected_collection.products_count > 0 %}
      <div class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-3 lg:grid-cols-4">
        {% for product in selected_collection.products limit: products_to_show %}
          <div class="flex justify-center">
            {% render 'custom-product-card', product: product, section: section %}
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="rounded-[16px] border border-[#D7D7D7] p-6 text-center text-[#666666]">
        Select a collection in the section settings.
      </div>
    {% endif %}
  </div>
</section>